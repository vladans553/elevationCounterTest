<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cloud Remote Fast Suite" parallel="none">

    <!-- Globalni parametri za ceo Suite -->
    <parameter name="executionType" value="local" />
    <parameter name="sessionType" value="class" />
     <parameter name="headless" value="true" />

    <test name="Remote Edge Fast Execution">
        <!-- Specifičan browser za ovaj test blok -->
        <parameter name="browser" value="edge" />
        <classes>
            <class name="tests.TvojaTestKlasa" />
            <!-- Možeš dodati još klasa, sve će koristiti isti browser prozor -->
        </classes>
    </test>

    <test name="Remote Firefox Fast Execution">
        <parameter name="browser" value="firefox" />
        <classes>
            <class name="tests.DrugaTestKlasa" />
        </classes>
    </test>

</suite>